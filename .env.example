# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key

# S3 Configuration
S3_BUCKET_NAME=ashoka-content-bucket

# DynamoDB Tables
DYNAMODB_SESSIONS_TABLE=ashoka-sessions
DYNAMODB_AUDIT_TABLE=ashoka-audit-logs
DYNAMODB_ALERTS_TABLE=ashoka-alerts
DYNAMODB_USERS_TABLE=ashoka-users
DYNAMODB_CONTENT_TABLE=ashoka-content

# DuckDB
DUCKDB_PATH=data/ashoka.duckdb

# Database Mode (set to true to use real DynamoDB, false for local DuckDB)
USE_REAL_DYNAMODB=false

# AI Engine Configuration
# Primary AI Engine: gemini or sarvam
PRIMARY_AI_ENGINE=gemini

# Google Gemini Configuration (Engine 1 - Primary)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash
USE_GEMINI=true
# Free Tier: 50 requests/day for gemini-2.0-flash, 20 requests/day for gemini-2.5-flash

# Sarvam AI Configuration (Engine 2 - Secondary Backup)
SARVAM_API_KEY=your_sarvam_api_key_here
SARVAM_MODEL=sarvam-m
# Free Tier: Check https://www.sarvam.ai for current limits
# Valid models: sarvam-m, sarvam-30b, sarvam-30b-16k, sarvam-105b, sarvam-105b-32k
# Supports: Text generation, sentiment analysis, content transformation
# Strong support for Indian languages (Hindi, Tamil, Kannada, etc.)

# Google Gemini Engine 3 Configuration (Tertiary - Additional Gemini Backup)
GEMINI_ENGINE3=your_second_gemini_api_key_here
GEMINI_MODEL_ENGINE3=gemini-2.0-flash
# Free Tier: 50 requests/day for gemini-2.0-flash
# Use a different Gemini API key to get additional quota (50 more requests/day)
# This provides a total of 100 free Gemini requests/day when combined with Engine 1
# Fallback order: Gemini Engine 1 → Sarvam AI → Gemini Engine 3

# Session Configuration
SESSION_TIMEOUT_MINUTES=30
OTP_EXPIRATION_MINUTES=5

# API Configuration
API_RATE_LIMIT=100

# Logging
LOG_LEVEL=INFO

# NiceGUI Storage Configuration
# REQUIRED: Secret key for encrypting session storage (app.storage.general)
# Generate a secure random string with: python -c "import secrets; print(secrets.token_urlsafe(48))"
# Minimum 32 characters recommended for security
STORAGE_SECRET=your_storage_secret_here_minimum_32_characters
